[Unit]
Description=MITM Go Server
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/mitm-go-server
EnvironmentFile=-/opt/mitm-go-server/.env
ExecStart=/opt/mitm-go-server/mitm-api
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
