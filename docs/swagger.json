            "type": "object",
            "required": [
                "amount",
                "balanceBefore",
                "bankId",
                "direction",
                "recipientCardNumber",
                "time"
            ],
            "properties": {
                "amount": {
                    "type": "number",
                    "example": 5000
                },
                "balanceBefore": {
                    "type": "number",
                    "example": 22096.74
                },
                "bankId": {
                    "type": "string",
                    "example": "tbank"
                },
                "direction": {
                    "type": "string",
                    "enum": [
                        "OUTGOING",
                        "INCOMING"
                    ],
                    "example": "OUTGOING"
                },
                "recipientCardNumber": {
                    "type": "string",
                    "example": "1234 5678 9100 0000"
                },
                "time": {
                    "type": "string",
                    "example": "2026-05-16T22:14:12+0700"
                }
            }
        },
