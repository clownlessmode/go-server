        "landing_bundle_config": "{\"is_landing_bundle_enabled\":true,\"socRefuseTariff\":\"NOBUNIND\",\"urlVideoTariff\":\"https://static.beeline.ru/upload/images/video/pomosh/30075-tarify-s-gibkoi-oplatoi.mp4\",\"faq\":[{\"title\":\"Можно ли остаться на прежнем тарифе?\",\"description\":\"Да, вы можете вернуть прежний тариф. В таком случае условия и стоимость не изменятся.\",\"sortOrder\":1},{\"title\":\"Как вернуть прежний тариф?\",\"description\":\"Вернуться на прежний тариф вы можете на этой странице или через звонок по номеру 0611.\",\"sortOrder\":2},{\"title\":\"Почему тариф меняется?\",\"description\":\"Мы стараемся сделать условия более комфортными для вас. Поэтому предлагаем попробовать новый тариф с индивидуальными параметрами. Если не понравится — вы сможете вернуться на прежний тариф. Стоимость для вас не изменится.\",\"sortOrder\":3},{\"title\":\"Как узнать параметры нового тарифа?\",\"description\":\"Мы отправили их вам в персональном SMS. Также ознакомиться с ними вы можете на этой странице.\",\"sortOrder\":4}]}",
        "landing_offset_config": "{   \"faq\": [     {       \"title\": \"Новые условия\",       \"questions\": [         {           \"subtitle\": \"Почему изменяются цены на связь?\",           \"description\": \"Происходящие экономические изменения влияют на жизнь каждого из нас. В текущих условиях мы стремимся поддержать на высоком уровне качество связи, чтобы наши клиенты могли сохранить доступ ко всем сервисам и услугам, которые им важны в повседневной жизни. За последние пару лет, когда общение, работа и развлечения перешли в онлайн, использование интернета выросло более чем в два раза. При столь значимом росте потребления поддержание высокой скорости интернета невозможно без существенных инвестиций в развитие сети. В условиях текущих экономических изменений стоимость оборудования активно растёт вместе с инфляцией, изменением курсов валют, в связи с дефицитом комплектующих и т. д. Повышение стоимости наших услуг позволит поддержать на высоком уровне качество связи и развивать новые технологии, в которых нуждаются наши клиенты сегодня и будут нуждаться завтра.\",           \"sortOrder\": 1         },         {           \"subtitle\": \"Как вы информируете об изменениях?\",           \"description\": \"Мы понимаем, как важно контролировать затраты на связь, поэтому заранее сообщаем клиентам о предстоящих изменениях. Не менее чем за 10 дней публикуем новость об изменениях на сайте beeline.ru, каждому клиенту отправляем персональное SMS с информацией о том, что поменялось в его тарифе, а также размещаем эту информацию в мобильном приложении и личном кабинете абонента.\",           \"sortOrder\": 2         },         {           \"subtitle\": \"Можно ли вернуть прежние условия?\",           \"description\": \"Потребности наших клиентов индивидуальны и часто меняются с течением времени, поэтому при повышении стоимости услуг связи мы предлагаем каждому клиенту дополнительные бонусы, которые помогут адаптировать действующий тариф в соответствии с его личными предпочтениями. Также в любой момент, как в период информирования, так и после изменения цен, можно перейти на любой актуальный тариф, соответствующий вашим текущим потребностям.\",           \"sortOrder\": 3         }       ]     },     {       \"title\": \"Списания\",       \"questions\": [         {           \"subtitle\": \"Когда спишется обновлённая плата на тарифе с ежемесячной системой расчёта?\",           \"description\": \"В привычную дату для каждого абонента с ежемесячным списанием, следующую за датой изменения тарифа.\",           \"sortOrder\": 1         }       ]     },     {       \"title\": \"Скидки и бонусы\",       \"questions\": [         {           \"subtitle\": \"Будет ли действовать скидка после изменений?\",           \"description\": \"Наши клиенты как участники различного рода акций могут пользоваться скидками, которые действуют в течение заявленного срока. Изменение стоимости тарифа не влияет на предоставление скидки. После вступления изменений в силу скидка будет применяться к новой стоимости тарифа.\",           \"sortOrder\": 1         },         {           \"subtitle\": \"Будет ли доступен бонус после смены тарифа?\",           \"description\": \"Бонус предоставляется только на тарифе с изменяемой стоимостью. При переходе на другой тариф бонус доступен не будет.\",           \"sortOrder\": 2         }       ]     }   ] }",
